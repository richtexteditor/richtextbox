<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="RichTextBox">
      <HintPath>..\lib\RichTextBox.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <!-- Transitive dependency of the protected RichTextBox.dll (DocxExporter uses it). -->
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.1.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="RichTextBox.lic" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
