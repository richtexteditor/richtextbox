                    <a class="site-footer-link block no-underline" href="/Demos/Overview">Demos</a>
                    <a class="site-footer-link block no-underline" href="/GettingStarted">Getting Started</a>
                    <a class="site-footer-link block no-underline" href="/Installation">Installation</a>
                    <a class="site-footer-link block no-underline" href="/ClassReference">Class Reference</a>
                    <a class="site-footer-link block no-underline" href="/FAQ">FAQ</a>
                    <a class="site-footer-link block no-underline" href="/Requirements">Requirements</a>
                    <a class="site-footer-link block no-underline" href="/Deployment">Deployment</a>
                    <a class="site-footer-link block no-underline" href="/Download">Download</a>
                </div>
            </div>

            <div>
                <h2 class="font-['Sora'] text-sm font-semibold uppercase tracking-[0.24em] text-slate-900">Platforms</h2>
