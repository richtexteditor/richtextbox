                    <a class="site-footer-link block no-underline" href="https://mylivechat.com" target="_blank" rel="noopener">MyLiveChat</a>
                    <a class="site-footer-link block no-underline" href="https://multipleupload.com" target="_blank" rel="noopener">Multiple Upload</a>
                    <a class="site-footer-link block no-underline" href="https://coreupload.com" target="_blank" rel="noopener">CoreUpload</a>
                </div>
            </div>

            <div>
                <h2 class="font-['Sora'] text-sm font-semibold uppercase tracking-[0.24em] text-slate-900">Contact</h2>
                <div class="mt-5 space-y-3">
                    <a class="site-footer-link block no-underline" href="mailto:sales@richtexteditor.net">sales@richtexteditor.net</a>
                    <a class="site-footer-link block no-underline" href="mailto:support@richscripts.com">support@richscripts.com</a>
                    <a class="site-footer-link block no-underline" href="https://clientcenter.richscripts.com/MvcFolder/Product.ascx?ProductId=5">Official Purchase Page</a>
                </div>
                <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="mb-1 font-['Sora'] text-sm font-semibold text-slate-950">Richscripts Inc.</p>
