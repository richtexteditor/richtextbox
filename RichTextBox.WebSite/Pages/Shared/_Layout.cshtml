@{
    var currentPath = ViewContext.HttpContext.Request.Path.Value?.ToLowerInvariant() ?? "/";
    string NavClass(string section) {
        bool active = section switch {
            "home" => currentPath == "/" || currentPath == "/index",
            "demos" => currentPath.StartsWith("/demos"),
            "docs" => currentPath.StartsWith("/features") || currentPath.StartsWith("/document"),
            "pricing" => currentPath.StartsWith("/pricing") || currentPath.StartsWith("/download"),
            _ => false
        };
        return "site-nav-link" + (active ? " is-active" : "");
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "RichTextBox for ASP.NET Core")</title>
    <meta name="keywords" content="ASP.NET Core Rich Text Editor, WYSIWYG editor, HTML editor, Razor Pages editor, rich text box, content editor, image gallery upload, context menu, office skin" />
    <meta name="description" content="RichTextBox is an ASP.NET Core WYSIWYG editor with 50+ features: image gallery upload, content templates, context menus, autosave, Office-style skins, and a downloadable client trial bundle." />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { DEFAULT: "#0891b2", deep: "#155e75", ink: "#0f172a" }
                    },
                    boxShadow: {
                        panel: "0 30px 60px -28px rgba(15, 23, 42, 0.35)"
                    }
                }
            }
        };
    </script>
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
