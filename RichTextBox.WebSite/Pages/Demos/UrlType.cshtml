@page
@{
    ViewData["Title"] = "URL Type";
    ViewData["DemoNumber"] = 90;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">URL Type</div>
                <div class="demo-card-body">
                    <p class="demo-description">Control how URLs are processed in the editor content. Use relative to convert to relative paths or absolute to convert to full URLs.</p>

                    <h4 style="margin-bottom:8px">url-type="relative"</h4>
                    <richtextbox
                        id="urlTypeRelative"
                        name="urlTypeRelative"
                        toolbar="default"
                        width="100%"
                        height="200px"
                        url-type="relative"
                        html="<p>This editor converts all URLs to relative paths. Insert a link or image and inspect the HTML to see the URL format.</p>"></richtextbox>

                    <h4 style="margin-top:24px;margin-bottom:8px">url-type="absolute"</h4>
                    <richtextbox
                        id="urlTypeAbsolute"
                        name="urlTypeAbsolute"
                        toolbar="default"
                        width="100%"
                        height="200px"
                        url-type="absolute"
                        html="<p>This editor converts all URLs to absolute paths. Insert a link or image and inspect the HTML to see the full URL.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="urlTypeRelative"
    toolbar="default"
    height="200px"
    url-type="relative" /&gt;

&lt;richtextbox
    name="urlTypeAbsolute"
    toolbar="default"
    height="200px"
    url-type="absolute" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
