@page
@{
    ViewData["Title"] = "Word & Character Count";
    ViewData["DemoNumber"] = 73;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Word &amp; Character Count</div>
                <div class="demo-card-body">
                    <p class="demo-description">Display word count, character count, and paragraph statistics in the editor's bottom bar. The counts update in real time as you type.</p>
                    <richtextbox name="showStatisticsEditor" toolbar="default" height="300px" show-statistics="true" html="<p>The bottom bar shows content statistics including word and character counts. Add or remove text to see the statistics update in real time.</p><p>This is useful for writers who need to track document length and stay within guidelines.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    show-statistics="true"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
