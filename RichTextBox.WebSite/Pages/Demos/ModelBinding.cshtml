@page
@{
    ViewData["Title"] = "Model Binding";
    ViewData["DemoNumber"] = 85;
    var postedBody = Request.HasFormContentType ? Request.Form["Body"].ToString() : null;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Model Binding</div>
                <div class="demo-card-body">
                    <p class="demo-description">Use asp-for to bind the editor to a PageModel property for automatic model binding on form submission.</p>

                    <form method="post">
                        <richtextbox
                            id="modelBindingEditor"
                            name="Body"
                            toolbar="default"
                            width="100%"
                            height="300px"
                            html="<p>This editor uses model binding. Edit the content and submit the form to see the posted value.</p>"></richtextbox>

                        <div style="margin-top:12px">
                            <button type="submit" class="btn btn-primary">Submit</button>
                        </div>
                    </form>

                    @if (!string.IsNullOrEmpty(postedBody))
                    {
                        <div style="margin-top:16px;padding:12px;border:1px solid #ccc;border-radius:4px;background:#f9f9f9">
                            <strong>Posted Value:</strong>
                            <pre style="white-space:pre-wrap">@postedBody</pre>
                        </div>
                    }

                    <div class="code-panel">
                        <pre><code>// PageModel
[BindProperty]
public string Body { get; set; }

// Razor Page
&lt;form method="post"&gt;
    &lt;richtextbox asp-for="Body"
        toolbar="default"
        height="300px" /&gt;
    &lt;button type="submit"&gt;Submit&lt;/button&gt;
&lt;/form&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
