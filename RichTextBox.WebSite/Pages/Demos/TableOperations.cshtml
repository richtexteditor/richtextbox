@page
@{
    ViewData["Title"] = "Table Operations";
    ViewData["DemoNumber"] = 28;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Table Operations</div>
                <div class="demo-card-body">
                    <p class="demo-description">Right-click on table cells to access row insert, column insert, cell merge, cell split, and delete operations through the context menu.</p>

                    <richtextbox
                        id="tableOpsEditor"
                        name="tableOpsEditor"
                        toolbar="default"
                        width="100%"
                        height="350px"
                        enable-context-menu="true"
                        context-menu-mode="Default"
                        html="<p>Right-click any cell in the table below to access table operations:</p><table border='1' style='width:100%;border-collapse:collapse'><tr><th>Name</th><th>Role</th><th>Status</th></tr><tr><td>Alice</td><td>Developer</td><td>Active</td></tr><tr><td>Bob</td><td>Designer</td><td>Active</td></tr><tr><td>Carol</td><td>Manager</td><td>On Leave</td></tr></table>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="tableOpsEditor"
    toolbar="default"
    height="350px"
    enable-context-menu="true"
    context-menu-mode="Default"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
