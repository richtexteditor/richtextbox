@page
@{
    ViewData["Title"] = "Indent & Outdent";
    ViewData["DemoNumber"] = 24;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Indent & Outdent</div>
                <div class="demo-card-body">
                    <p class="demo-description">Increase or decrease the indentation level of paragraphs and list items.</p>

                    <richtextbox
                        id="indentEditor"
                        name="indentEditor"
                        toolbar="{indent,outdent,insertorderedlist,insertunorderedlist}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="300px"
                        html="<p>Normal paragraph.</p><blockquote style='margin-left:40px'><p>This paragraph is indented one level. Use the indent button to push content further right, or outdent to move it back.</p></blockquote>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="indentEditor"
    toolbar="{indent,outdent,insertorderedlist,insertunorderedlist}|{bold,italic}|{undo,redo}"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
