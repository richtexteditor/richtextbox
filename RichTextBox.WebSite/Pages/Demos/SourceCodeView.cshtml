@page
@{
    ViewData["Title"] = "Source Code View";
    ViewData["DemoNumber"] = 92;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Source Code View</div>
                <div class="demo-card-body">
                    <p class="demo-description">Toggle between WYSIWYG and HTML source code view using the code button in the toolbar.</p>

                    <richtextbox
                        id="sourceCodeEditor"
                        name="sourceCodeEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<h2>WYSIWYG View</h2><p>Click the <strong>code</strong> button in the toolbar to switch to HTML source view. Click it again to return to the visual editor.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="sourceCodeEditor"
    toolbar="default"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
