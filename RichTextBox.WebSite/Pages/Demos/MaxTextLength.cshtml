@page
@{
    ViewData["Title"] = "Max Text Length";
    ViewData["DemoNumber"] = 71;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Max Text Length</div>
                <div class="demo-card-body">
                    <p class="demo-description">Limit the visible text character count, excluding HTML tags. The statistics bar shows the current count against the 200-character limit.</p>
                    <richtextbox name="maxTextLengthEditor" toolbar="default" height="300px" max-text-length="200" show-statistics="true" html="<p>This editor limits visible text to 200 characters. HTML tags do not count toward the limit — only the rendered text.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    max-text-length="200"
    show-statistics="true"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
