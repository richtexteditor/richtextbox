@page
@{
    ViewData["Title"] = "Ajax Submit";
    ViewData["DemoNumber"] = 87;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Ajax Submit</div>
                <div class="demo-card-body">
                    <p class="demo-description">Submit editor content via JavaScript fetch() instead of a traditional form post. The response is displayed without a page reload.</p>

                    <richtextbox
                        id="ajaxEditor"
                        name="ajaxEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<p>Edit this content and click the Ajax Submit button below. The content will be sent via fetch() without a page reload.</p>"></richtextbox>

                    <div style="margin-top:12px">
                        <button type="button" class="btn btn-primary" onclick="submitAjax()">Ajax Submit</button>
                    </div>

                    <div id="ajaxResult" style="margin-top:16px;padding:12px;border:1px solid #ccc;border-radius:4px;background:#f9f9f9;display:none">
                        <strong>Submitted HTML:</strong>
                        <pre id="ajaxOutput" style="white-space:pre-wrap"></pre>
                    </div>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox id="ajaxEditor" name="ajaxEditor"
    toolbar="default" height="300px" /&gt;

&lt;button onclick="submitAjax()"&gt;Ajax Submit&lt;/button&gt;

&lt;script&gt;
function submitAjax() {
    var editor = document.getElementById('ajaxEditor');
    var html = editor.value;

    fetch('/api/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ html: html })
    })
    .then(response =&gt; response.json())
    .then(data =&gt; console.log('Saved:', data));
}
&lt;/script&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function submitAjax() {
    var editor = document.getElementById('ajaxEditor');
    var html = editor.value;
    document.getElementById('ajaxOutput').textContent = html;
    document.getElementById('ajaxResult').style.display = 'block';
}
</script>
}
