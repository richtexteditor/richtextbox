@page
@{
    ViewData["Title"] = "Editor Body Inline CSS";
    ViewData["DemoNumber"] = 53;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Editor Body Inline CSS</div>
                <div class="demo-card-body">
                    <p class="demo-description">Apply inline CSS directly to the editor body element using editor-body-css-text. Useful for quick style adjustments like background color or padding.</p>
                    <richtextbox name="editorBodyCssTextEditor" toolbar="default" height="300px" editor-body-css-text="background-color: #f9fafb; padding: 20px;" html="<p>This editor has inline styles applied to its body — a light gray background and extra padding for a comfortable editing area.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    editor-body-css-text="background-color: #f9fafb; padding: 20px;"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
