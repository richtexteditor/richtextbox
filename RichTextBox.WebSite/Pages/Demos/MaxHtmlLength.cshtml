@page
@{
    ViewData["Title"] = "Max HTML Length";
    ViewData["DemoNumber"] = 70;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Max HTML Length</div>
                <div class="demo-card-body">
                    <p class="demo-description">Limit the total character count including HTML tags. The statistics bar shows the current count and the editor enforces the limit during editing.</p>
                    <richtextbox name="maxHtmlLengthEditor" toolbar="default" height="300px" max-html-length="500" show-statistics="true" html="<p>This editor limits total HTML to 500 characters including tags. The statistics bar shows the current count.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    max-html-length="500"
    show-statistics="true"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
