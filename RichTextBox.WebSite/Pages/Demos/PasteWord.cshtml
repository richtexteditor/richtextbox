@page
@{
    ViewData["Title"] = "Paste from Word";
    ViewData["DemoNumber"] = 62;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Paste from Word</div>
                <div class="demo-card-body">
                    <p class="demo-description">The Word paste mode cleans Microsoft Word-specific markup while preserving essential formatting like bold, italic, lists, and tables.</p>
                    <richtextbox name="pasteWordEditor" toolbar="default" height="300px" paste-mode="Word" html="<p>Copy formatted text from Microsoft Word and paste it here. The editor preserves essential formatting while stripping Word-specific markup like mso styles and XML tags.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    paste-mode="Word"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
