@page
@{
    ViewData["Title"] = "Editor Body CSS Class";
    ViewData["DemoNumber"] = 52;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Editor Body CSS Class</div>
                <div class="demo-card-body">
                    <p class="demo-description">Apply a custom CSS class to the editor body element. This lets you target editor content with existing stylesheets or framework utility classes.</p>
                    <richtextbox name="editorBodyCssEditor" toolbar="default" height="300px" editor-body-css-class="custom-editor-body" html="<p>This editor has a custom CSS class applied to its body element. You can use this to hook into existing stylesheets or framework classes.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    editor-body-css-class="custom-editor-body"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
