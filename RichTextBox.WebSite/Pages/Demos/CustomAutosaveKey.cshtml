@page
@{
    ViewData["Title"] = "Custom Autosave Key";
    ViewData["DemoNumber"] = 56;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Custom Autosave Key</div>
                <div class="demo-card-body">
                    <p class="demo-description">Specify a custom localStorage key for autosave with auto-save-key. This prevents collisions when multiple editors share the same page.</p>
                    <richtextbox name="customAutosaveKeyEditor" toolbar="default" height="300px" auto-save="true" auto-save-key="my-editor-draft" html="<p>This editor saves drafts under the key &amp;quot;my-editor-draft&amp;quot; in localStorage.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    auto-save="true"
    auto-save-key="my-editor-draft"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
