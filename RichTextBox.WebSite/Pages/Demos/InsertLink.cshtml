@page
@{
    ViewData["Title"] = "Insert Link";
    ViewData["DemoNumber"] = 30;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Insert Link</div>
                <div class="demo-card-body">
                    <p class="demo-description">Add hyperlinks to selected text using the insert link dialog. Set URL, target, and title attributes.</p>

                    <richtextbox
                        id="insertLinkEditor"
                        name="insertLinkEditor"
                        toolbar="{insertlink,unlink}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="300px"
                        html="<p>Select text and click the link button to create a hyperlink. You can also type a URL directly and the editor will auto-detect it.</p><p>Example: <a href='https://example.com'>Click this existing link</a> to see how links appear in the editor.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="insertLinkEditor"
    toolbar="{insertlink,unlink}|{bold,italic}|{undo,redo}"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
