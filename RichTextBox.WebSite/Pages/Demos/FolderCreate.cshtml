@page
@{
    ViewData["Title"] = "Folder Create";
    ViewData["DemoNumber"] = 77;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Folder Create</div>
                <div class="demo-card-body">
                    <p class="demo-description">Create new folders within the image gallery dialog to organize uploaded images. The gallery endpoint handles folder creation on the server.</p>

                    <richtextbox
                        id="folderCreateEditor"
                        name="folderCreateEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<p>In the image gallery dialog, use the Create Folder button to organize your uploaded images into logical groups.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="folderCreateEditor"
    toolbar="default"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
