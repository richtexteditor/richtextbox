@page
@{
    ViewData["Title"] = "Ordered List";
    ViewData["DemoNumber"] = 21;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Ordered List</div>
                <div class="demo-card-body">
                    <p class="demo-description">Create numbered lists with the ordered list button. Supports decimal, lower-alpha, upper-alpha, lower-roman, and upper-roman styles.</p>

                    <richtextbox
                        id="orderedListEditor"
                        name="orderedListEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<ol><li>First item</li><li>Second item</li><li>Third item</li></ol><p>Place your cursor and click the ordered list button to start a new list.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="orderedListEditor"
    toolbar="default"
    height="300px"
    html="&lt;ol&gt;&lt;li&gt;First item&lt;/li&gt;&lt;li&gt;Second item&lt;/li&gt;&lt;li&gt;Third item&lt;/li&gt;&lt;/ol&gt;" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
