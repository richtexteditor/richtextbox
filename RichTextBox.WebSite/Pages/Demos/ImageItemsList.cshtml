@page
@{
    ViewData["Title"] = "Image Items List";
    ViewData["DemoNumber"] = 78;
    var imageItemsJson = System.Text.Json.JsonSerializer.Serialize(new[]
    {
        new { name = "Microsoft Logo", url = "/images/microsoft.svg", thumbUrl = "/images/microsoft.svg" },
        new { name = "Intel Logo", url = "/images/Intel.svg", thumbUrl = "/images/Intel.svg" },
        new { name = "Sample Photo", url = "/images/sample-photo.jpg", thumbUrl = "/images/sample-photo.jpg" },
        new { name = "Editor Banner", url = "/images/richtexteditor.png", thumbUrl = "/images/richtexteditor.png" }
    });
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Image Items List</div>
                <div class="demo-card-body">
                    <p class="demo-description">Pre-populate the image URL insert dialog with a list of quick-access image entries using image-items-json.</p>

                    <richtextbox
                        id="imageItemsEditor"
                        name="imageItemsEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        image-items-json="@imageItemsJson"
                        html="<p>Open the Insert Image dialog to see the pre-populated image list.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>@@{
    var imageItemsJson = System.Text.Json.JsonSerializer.Serialize(new[]
    {
        new { name = "Microsoft Logo", url = "/images/microsoft.svg", thumbUrl = "/images/microsoft.svg" },
        new { name = "Intel Logo", url = "/images/Intel.svg", thumbUrl = "/images/Intel.svg" },
        new { name = "Sample Photo", url = "/images/sample-photo.jpg", thumbUrl = "/images/sample-photo.jpg" }
    });
}

&lt;richtextbox
    name="imageItemsEditor"
    toolbar="default"
    height="300px"
    image-items-json="@@imageItemsJson" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
