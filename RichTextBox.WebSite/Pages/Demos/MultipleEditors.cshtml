@page
@{
    ViewData["Title"] = "Multiple Editors";
    ViewData["DemoNumber"] = 84;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Multiple Editors</div>
                <div class="demo-card-body">
                    <p class="demo-description">Multiple independent editor instances can coexist on the same page, each with its own configuration. This is useful when a form requires separate rich text fields such as a main article body and a sidebar or summary.</p>

                    <h4 style="margin-bottom:8px">Main Article</h4>
                    <richtextbox
                        id="editor1"
                        name="editor1"
                        toolbar="default"
                        width="100%"
                        height="250px"
                        html="<h3>Introducing Our New Dashboard</h3><p>We are thrilled to announce the launch of the redesigned analytics dashboard. The new interface features real-time data visualization, customizable widgets, and a streamlined navigation that puts the most important metrics front and center.</p><p>Key improvements include faster load times, dark mode support, and the ability to export reports in multiple formats. We believe these changes will help teams make data-driven decisions more efficiently than ever before.</p>"></richtextbox>

                    <h4 style="margin-top:24px;margin-bottom:8px">Sidebar Widget</h4>
                    <richtextbox
                        id="editor2"
                        name="editor2"
                        toolbar="basic"
                        width="100%"
                        height="200px"
                        html="<p><strong>Quick Links</strong></p><ul><li>View the full release notes</li><li>Watch the feature walkthrough video</li><li>Submit feedback to the product team</li></ul>"></richtextbox>

                    <div class="demo-note">
                        <div class="demo-note-content">
                            <div class="demo-note-title">Note</div>
                            <p class="demo-note-text">Each editor maintains its own state and configuration. Give each a unique name attribute for form submission.</p>
                        </div>
                    </div>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    id="editor1"
    name="editor1"
    toolbar="default"
    height="250px"
    html="..." /&gt;

&lt;richtextbox
    id="editor2"
    name="editor2"
    toolbar="basic"
    height="200px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
