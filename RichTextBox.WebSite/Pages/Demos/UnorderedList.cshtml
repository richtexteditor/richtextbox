@page
@{
    ViewData["Title"] = "Unordered List";
    ViewData["DemoNumber"] = 22;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Unordered List</div>
                <div class="demo-card-body">
                    <p class="demo-description">Create bullet lists with disc, circle, or square marker styles.</p>

                    <richtextbox
                        id="unorderedListEditor"
                        name="unorderedListEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<ul><li>First bullet point</li><li>Second bullet point</li><li>Third bullet point</li></ul><p>Use the unordered list button to toggle bullet list formatting on the current paragraph.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="unorderedListEditor"
    toolbar="default"
    height="300px"
    html="&lt;ul&gt;&lt;li&gt;First bullet point&lt;/li&gt;&lt;li&gt;Second bullet point&lt;/li&gt;&lt;li&gt;Third bullet point&lt;/li&gt;&lt;/ul&gt;" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
