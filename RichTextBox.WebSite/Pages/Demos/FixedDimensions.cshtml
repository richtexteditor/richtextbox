@page
@{
    ViewData["Title"] = "Fixed Dimensions";
    ViewData["DemoNumber"] = 69;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Fixed Dimensions</div>
                <div class="demo-card-body">
                    <p class="demo-description">Set explicit pixel dimensions for both width and height. The editor maintains its exact size regardless of the container.</p>
                    <richtextbox name="fixedDimensionsEditor" toolbar="default" width="600px" height="400px" html="<p>This editor has a fixed width of 600px and height of 400px. It does not resize or respond to container changes.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    width="600px"
    height="400px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
