@page
@{
    ViewData["Title"] = "Custom Autosave Delay";
    ViewData["DemoNumber"] = 57;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Custom Autosave Delay</div>
                <div class="demo-card-body">
                    <p class="demo-description">Control how frequently drafts are saved with auto-save-delay. This example saves every 2 seconds instead of the default 700ms interval.</p>
                    <richtextbox name="customAutosaveDelayEditor" toolbar="default" height="300px" auto-save="true" auto-save-delay="2000" html="<p>This editor autosaves every 2 seconds (2000ms) instead of the default 700ms delay.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    auto-save="true"
    auto-save-delay="2000"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
