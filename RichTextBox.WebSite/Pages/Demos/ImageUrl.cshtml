@page
@{
    ViewData["Title"] = "Image by URL";
    ViewData["DemoNumber"] = 33;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Image by URL</div>
                <div class="demo-card-body">
                    <p class="demo-description">Insert images by specifying a URL. The dialog lets you set alt text, dimensions, and alignment.</p>

                    <richtextbox
                        id="imageUrlEditor"
                        name="imageUrlEditor"
                        toolbar="{insertimage}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="350px"
                        html="<p>Click the image button in the toolbar and select 'From URL' to insert an image by its web address.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="imageUrlEditor"
    toolbar="{insertimage}|{bold,italic}|{undo,redo}"
    height="350px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
