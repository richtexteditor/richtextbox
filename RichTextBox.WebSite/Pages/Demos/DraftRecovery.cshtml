@page
@{
    ViewData["Title"] = "Draft Recovery";
    ViewData["DemoNumber"] = 59;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Draft Recovery</div>
                <div class="demo-card-body">
                    <p class="demo-description">Drafts saved via autosave survive page refreshes and browser restarts. Edit the content below, refresh the page, and your changes will be restored automatically.</p>
                    <richtextbox name="draftRecoveryEditor" toolbar="default" height="300px" auto-save="true" html="<p>Edit this text, then refresh the page. Your draft will be recovered from localStorage automatically.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    auto-save="true"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
