@page
@{
    ViewData["Title"] = "Gallery Browse";
    ViewData["DemoNumber"] = 76;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Gallery Browse</div>
                <div class="demo-card-body">
                    <p class="demo-description">Browse uploaded images organized by folder in the gallery dialog. Provides folder navigation, search, and thumbnail previews.</p>

                    <richtextbox
                        id="galleryBrowseEditor"
                        name="galleryBrowseEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<p>Open the image gallery to browse previously uploaded images. Navigate folders, search by name, and click to insert.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="galleryBrowseEditor"
    toolbar="default"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
