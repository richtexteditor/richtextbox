@page
@{
    ViewData["Title"] = "Basic Toolbar";
    ViewData["DemoNumber"] = 8;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Basic Toolbar</div>
                <div class="demo-card-body">
                    <p class="demo-description">The basic toolbar is ideal for simple text input scenarios like comments, short messages, or email composition. It provides essential formatting without the complexity of image uploads or table editing.</p>

                    <richtextbox
                        id="basicToolbarEditor"
                        name="basicToolbarEditor"
                        toolbar="basic"
                        skin="default"
                        width="100%"
                        height="300px"
                        html="<p>Hi Alex,</p><p>Just a quick note to confirm our meeting tomorrow at <strong>2:00 PM</strong> in Conference Room B. Please bring the latest sales figures and the updated proposal draft.</p><p>If you need to reschedule, let me know by end of day. You can also reach me on Slack or at <a href='mailto:jordan@example.com'>jordan@example.com</a>.</p><p>Best regards,<br />Jordan Miller<br /><em>Senior Account Manager</em></p>"></richtextbox>

                    <div class="demo-note">
                        <div class="demo-note-content">
                            <div class="demo-note-title">Note</div>
                            <p class="demo-note-text">Use the basic preset when you need text formatting without the complexity of image uploads or table editing.</p>
                        </div>
                    </div>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="basicToolbarEditor"
    toolbar="basic"
    skin="default"
    height="300px" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
