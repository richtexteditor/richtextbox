@page
@{
    ViewData["Title"] = "Background Color";
    ViewData["DemoNumber"] = 15;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Background Color</div>
                <div class="demo-card-body">
                    <p class="demo-description">Highlight text with a background color using the backcolor picker.</p>

                    <richtextbox
                        id="bgColorEditor"
                        name="bgColorEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<p>Select text and apply a <span style='background-color:#ffff00'>background highlight</span> using the <span style='background-color:#00ffff'>backcolor button</span> in the toolbar.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="bgColorEditor"
    toolbar="default"
    height="300px"
    html="&lt;p&gt;Select text and apply a &lt;span style='background-color:#ffff00'&gt;background highlight&lt;/span&gt; using the &lt;span style='background-color:#00ffff'&gt;backcolor button&lt;/span&gt;.&lt;/p&gt;" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
