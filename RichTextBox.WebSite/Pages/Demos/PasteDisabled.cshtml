@page
@{
    ViewData["Title"] = "Paste Disabled";
    ViewData["DemoNumber"] = 63;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Paste Disabled</div>
                <div class="demo-card-body">
                    <p class="demo-description">Disable paste functionality entirely to prevent external content from being inserted into the editor.</p>
                    <richtextbox name="pasteDisabledEditor" toolbar="default" height="300px" paste-mode="Disabled" html="<p>Paste is disabled in this editor. Ctrl+V and right-click paste will not insert content. This is useful for controlled input scenarios.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    paste-mode="Disabled"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
