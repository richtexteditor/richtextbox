@page
@{
    ViewData["Title"] = "Preview Mode";
    ViewData["DemoNumber"] = 93;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Preview Mode</div>
                <div class="demo-card-body">
                    <p class="demo-description">Preview the final rendered output of the editor content using the preview button in the toolbar.</p>

                    <richtextbox
                        id="previewModeEditor"
                        name="previewModeEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<h2>Preview This Content</h2><p>Click the <strong>preview</strong> button in the toolbar to see how the content will appear when rendered. The preview opens in a separate window.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="previewModeEditor"
    toolbar="default"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
