@page
@{
    ViewData["Title"] = "Code Blocks";
    ViewData["DemoNumber"] = 39;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Code Blocks</div>
                <div class="demo-card-body">
                    <p class="demo-description">Insert code blocks with syntax highlighting support for various programming languages.</p>

                    <richtextbox
                        id="codeInsertEditor"
                        name="codeInsertEditor"
                        toolbar="{insertcode}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="350px"
                        html="<p>Use the code button to insert formatted code blocks:</p><pre><code>function greet(name) {\n    return 'Hello, ' + name + '!';\n}</code></pre>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="codeInsertEditor"
    toolbar="{insertcode}|{bold,italic}|{undo,redo}"
    height="350px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
