@page
@{
    ViewData["Title"] = "Nested Lists";
    ViewData["DemoNumber"] = 29;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Nested Lists</div>
                <div class="demo-card-body">
                    <p class="demo-description">Create multi-level lists by combining ordered and unordered lists with indentation.</p>

                    <richtextbox
                        id="nestedListEditor"
                        name="nestedListEditor"
                        toolbar="{insertorderedlist,insertunorderedlist,indent,outdent}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="350px"
                        html="<ol><li>First level item<ul><li>Second level bullet</li><li>Another second level<ol><li>Third level numbered</li><li>Another third level</li></ol></li></ul></li><li>Back to first level</li></ol>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="nestedListEditor"
    toolbar="{insertorderedlist,insertunorderedlist,indent,outdent}|{bold,italic}|{undo,redo}"
    height="350px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
