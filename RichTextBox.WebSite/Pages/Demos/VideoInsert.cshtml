@page
@{
    ViewData["Title"] = "Insert Video";
    ViewData["DemoNumber"] = 35;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Insert Video</div>
                <div class="demo-card-body">
                    <p class="demo-description">Embed video content using the insert video dialog. Supports YouTube URLs and HTML5 video embedding.</p>

                    <richtextbox
                        id="videoInsertEditor"
                        name="videoInsertEditor"
                        toolbar="{insertvideo}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="350px"
                        html="<p>Click the video button in the toolbar to embed video content. Paste a YouTube URL or provide an HTML5 video source.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="videoInsertEditor"
    toolbar="{insertvideo}|{bold,italic}|{undo,redo}"
    height="350px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
