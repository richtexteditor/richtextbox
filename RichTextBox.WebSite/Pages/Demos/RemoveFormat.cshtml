@page
@{
    ViewData["Title"] = "Remove Format";
    ViewData["DemoNumber"] = 20;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Remove Format</div>
                <div class="demo-card-body">
                    <p class="demo-description">Strip all formatting from selected text, returning it to the default paragraph style.</p>

                    <richtextbox
                        id="removeFormatEditor"
                        name="removeFormatEditor"
                        toolbar="default"
                        width="100%"
                        height="300px"
                        html="<p><strong><em><span style='color:red;font-size:24px'>This text has multiple formatting layers applied.</span></em></strong> Select it and click Remove Format to strip everything back to plain text.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="removeFormatEditor"
    toolbar="default"
    height="300px"
    html="&lt;p&gt;&lt;strong&gt;&lt;em&gt;&lt;span style='color:red;font-size:24px'&gt;Formatted text&lt;/span&gt;&lt;/em&gt;&lt;/strong&gt; Select and click Remove Format.&lt;/p&gt;" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
