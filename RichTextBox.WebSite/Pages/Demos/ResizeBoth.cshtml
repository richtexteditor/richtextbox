@page
@{
    ViewData["Title"] = "Resize Both";
    ViewData["DemoNumber"] = 65;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Resize Both</div>
                <div class="demo-card-body">
                    <p class="demo-description">Allow users to resize the editor in both width and height by dragging the resize handle.</p>
                    <richtextbox name="resizeBothEditor" toolbar="default" height="300px" width="100%" resize-mode="both" html="<p>Drag the resize handle at the bottom-right corner to resize this editor in both dimensions.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    width="100%"
    resize-mode="both"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
