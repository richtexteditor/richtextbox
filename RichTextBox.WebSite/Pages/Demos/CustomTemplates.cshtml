@page
@{
    ViewData["Title"] = "Custom Templates";
    ViewData["DemoNumber"] = 41;
    var htmlTemplatesJson = System.Text.Json.JsonSerializer.Serialize(new[]
    {
        new { name = "Newsletter Header", html = "<div style='background:#1e293b;color:#fff;padding:24px;border-radius:8px;text-align:center'><h1 style='margin:0;color:#38bdf8'>Monthly Newsletter</h1><p style='margin:8px 0 0;color:#94a3b8'>Edition [Month] [Year]</p></div><p>Dear subscribers, welcome to this month's edition...</p>" },
        new { name = "Feature Card", html = "<div style='border:1px solid #e2e8f0;border-radius:12px;padding:20px;background:#f8fafc'><h3 style='margin:0 0 8px;color:#0f172a'>Feature Title</h3><p style='color:#475569;margin:0 0 12px'>Describe the key benefit or functionality of this feature in a short paragraph.</p><a href='#' style='color:#2563eb;font-weight:600'>Learn more &rarr;</a></div>" }
    });
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Custom Templates</div>
                <div class="demo-card-body">
                    <p class="demo-description">Design your own content templates with custom HTML layouts, styled sections, and brand colors.</p>

                    <richtextbox
                        id="customTemplatesEditor"
                        name="customTemplatesEditor"
                        toolbar="{bold,italic,underline,linethrough,superscript,subscript}|{forecolor,backcolor}|{justifyleft,justifycenter,justifyright,justifyfull}|{insertorderedlist,insertunorderedlist,multilevellist,inserttodolist,indent,outdent} #{paragraphs:toggle,fontname:toggle,fontsize:toggle,inlinestyle,lineheight,casechange}|{undo,redo} / {formatpainter,removeformat,cut,copy,paste,delete,find}|{insertlink,unlink,insertblockquote,insertemoji,insertchars}|{inserttable,insertbookmark,insertimage,insertgallery,insertvideo,insertdocument,inserttemplate,insertcode} #{preview,code,selectall}|{importword,exportword,exportpdf} / {insertcomment,trackchanges,insertmention}|{spellcheck,autoformatting,toggleborder}|{paragraphstyle,toggle_paragraphop,menu_paragraphop} #{insertmergefield,insertfootnote,inserttoc,insertpagebreak,revisionhistory}|{fullscreenenter,fullscreenexit,togglemore}"
                        width="100%"
                        height="400px"
                        html-templates-json="@htmlTemplatesJson"
                        html="<p>Click the Templates button to insert custom-styled content blocks with branded layouts.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>@@{
    var htmlTemplatesJson = JsonSerializer.Serialize(new[]
    {
        new { name = "Newsletter Header", html = "&lt;div style='background:#1e293b;...'&gt;...&lt;/div&gt;" },
        new { name = "Feature Card", html = "&lt;div style='border:1px solid #e2e8f0;...'&gt;...&lt;/div&gt;" }
    });
}

&lt;richtextbox
    name="customTemplatesEditor"
    toolbar="full"
    height="400px"
    html-templates-json="@@htmlTemplatesJson" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
