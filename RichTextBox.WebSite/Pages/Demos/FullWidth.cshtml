@page
@{
    ViewData["Title"] = "Full Width";
    ViewData["DemoNumber"] = 68;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Full Width</div>
                <div class="demo-card-body">
                    <p class="demo-description">Set the editor to fill its container width using width="100%". The editor responds to container size changes automatically.</p>
                    <richtextbox name="fullWidthEditor" toolbar="default" height="300px" width="100%" html="<p>This editor fills the full width of its container. Resize the browser window to see it adapt.</p>"></richtextbox>
                    <div class="code-panel">
<pre><code>&lt;richtextbox toolbar="default"
    height="300px"
    width="100%"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
