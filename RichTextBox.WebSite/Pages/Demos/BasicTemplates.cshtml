@page
@{
    ViewData["Title"] = "Basic Templates";
    ViewData["DemoNumber"] = 40;
    var htmlTemplatesJson = System.Text.Json.JsonSerializer.Serialize(new[]
    {
        new { name = "Announcement", html = "<h2>Announcement Title</h2><p>We are pleased to announce that <strong>[subject]</strong> is now available. Please review the details below and reach out with any questions.</p><p>Thank you for your attention.</p>" },
        new { name = "Meeting Notes", html = "<h2>Meeting Notes</h2><p><strong>Date:</strong> [date]</p><p><strong>Attendees:</strong> [names]</p><h3>Discussion Points</h3><ul><li>Point 1</li><li>Point 2</li></ul><h3>Action Items</h3><ul><li>[ ] Action item 1 - Owner</li><li>[ ] Action item 2 - Owner</li></ul>" }
    });
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Basic Templates</div>
                <div class="demo-card-body">
                    <p class="demo-description">Insert preconfigured content blocks from the template dialog. Templates are defined via the html-templates-json attribute.</p>

                    <richtextbox
                        id="basicTemplatesEditor"
                        name="basicTemplatesEditor"
                        toolbar="{bold,italic,underline,linethrough,superscript,subscript}|{forecolor,backcolor}|{justifyleft,justifycenter,justifyright,justifyfull}|{insertorderedlist,insertunorderedlist,multilevellist,inserttodolist,indent,outdent} #{paragraphs:toggle,fontname:toggle,fontsize:toggle,inlinestyle,lineheight,casechange}|{undo,redo} / {formatpainter,removeformat,cut,copy,paste,delete,find}|{insertlink,unlink,insertblockquote,insertemoji,insertchars}|{inserttable,insertbookmark,insertimage,insertgallery,insertvideo,insertdocument,inserttemplate,insertcode} #{preview,code,selectall}|{importword,exportword,exportpdf} / {insertcomment,trackchanges,insertmention}|{spellcheck,autoformatting,toggleborder}|{paragraphstyle,toggle_paragraphop,menu_paragraphop} #{insertmergefield,insertfootnote,inserttoc,insertpagebreak,revisionhistory}|{fullscreenenter,fullscreenexit,togglemore}"
                        width="100%"
                        height="400px"
                        html-templates-json="@htmlTemplatesJson"
                        html="<p>Click the Templates button in the toolbar to browse and insert predefined content blocks.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>@@{
    var htmlTemplatesJson = JsonSerializer.Serialize(new[]
    {
        new { name = "Announcement", html = "&lt;h2&gt;Announcement&lt;/h2&gt;..." },
        new { name = "Meeting Notes", html = "&lt;h2&gt;Meeting Notes&lt;/h2&gt;..." }
    });
}

&lt;richtextbox
    name="basicTemplatesEditor"
    toolbar="full"
    height="400px"
    html-templates-json="@@htmlTemplatesJson" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
