@page
@{
    ViewData["Title"] = "Minimal Setup";
    ViewData["DemoNumber"] = 2;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Minimal Setup</div>
                <div class="demo-card-body">
                    <p class="demo-description">The simplest possible editor setup requires only a name and height attribute. No toolbar, skin, or extra configuration is needed to get a fully functional rich text editor on your page.</p>

                    <richtextbox
                        name="Body"
                        height="300px"
                        html="<h3>Getting Started with Your Blog</h3><p>Writing great content starts with a clear structure. Begin with a compelling headline, follow it with an engaging introduction, and organize your thoughts into logical sections.</p><p>Here are a few tips to keep your readers engaged:</p><ul><li>Use short paragraphs and clear language</li><li>Add subheadings to break up long sections</li><li>Include relevant examples and anecdotes</li><li>End with a call to action or summary</li></ul>"></richtextbox>

                    <div class="demo-note">
                        <div class="demo-note-content">
                            <div class="demo-note-title">Note</div>
                            <p class="demo-note-text">The minimal setup uses the default toolbar automatically. Add toolbar, skin, and other attributes to customize further.</p>
                        </div>
                    </div>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox name="Body" height="300px" /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
