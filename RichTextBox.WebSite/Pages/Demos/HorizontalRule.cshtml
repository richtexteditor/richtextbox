@page
@{
    ViewData["Title"] = "Horizontal Rule";
    ViewData["DemoNumber"] = 26;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Horizontal Rule</div>
                <div class="demo-card-body">
                    <p class="demo-description">Insert a horizontal line to visually separate content sections.</p>

                    <richtextbox
                        id="hrEditor"
                        name="hrEditor"
                        toolbar="{inserthorizontalrule}|{bold,italic,underline}|{undo,redo}"
                        width="100%"
                        height="300px"
                        html="<p>Content above the divider.</p><hr/><p>Content below the divider. Click the horizontal rule button to insert a visual separator at the cursor position.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="hrEditor"
    toolbar="{inserthorizontalrule}|{bold,italic,underline}|{undo,redo}"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
