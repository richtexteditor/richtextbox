@page
@{
    ViewData["Title"] = "Special Characters";
    ViewData["DemoNumber"] = 38;
}
<div class="mx-auto max-w-screen-2xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[260px_1fr]">
        <partial name="Demos/_DemoLayout" />
        <div>
            <div class="demo-card">
                <div class="demo-card-header">Special Characters</div>
                <div class="demo-card-body">
                    <p class="demo-description">Insert special characters, symbols, and glyphs from the character map dialog. Includes Unicode, ASCII, European, Greek, Webdings, Wingdings, and Symbol sets.</p>

                    <richtextbox
                        id="specialCharsEditor"
                        name="specialCharsEditor"
                        toolbar="{insertchars}|{bold,italic}|{undo,redo}"
                        width="100%"
                        height="300px"
                        html="<p>Click the special characters button to browse character sets: Unicode symbols, European accented characters, Greek letters, and decorative fonts like Webdings and Wingdings.</p>"></richtextbox>

                    <div class="code-panel">
                        <pre><code>&lt;richtextbox
    name="specialCharsEditor"
    toolbar="{insertchars}|{bold,italic}|{undo,redo}"
    height="300px"
    html="..." /&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
