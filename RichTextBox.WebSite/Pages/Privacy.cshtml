@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <div class="rounded-[2rem] border border-white/70 bg-white/90 p-8 shadow-soft lg:p-12">
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-accent">Privacy</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink">Simple privacy placeholder for the new site shell.</h1>
        <p class="mt-6 text-base leading-8 text-slate-600">
            This ASP.NET Core site was created as a fresh marketing shell for richtextbox.com. Replace this page with your production privacy policy before launch.
        </p>
        <a asp-page="/Index" class="mt-8 inline-flex rounded-full border border-line px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-ink">Back to home</a>
    </div>
</section>
