            <pre class="overflow-x-auto text-sm leading-7 text-slate-300"><code><span class="text-slate-500">@@page</span>
<span class="text-slate-500">@@model</span> <span class="text-blue-300">MyPageModel</span>

<span class="text-pink-300">&lt;form</span> <span class="text-sky-300">method</span>=<span class="text-amber-300">"post"</span><span class="text-pink-300">&gt;</span>
    <span class="text-pink-300">&lt;richtextbox</span>
        <span class="text-sky-300">asp-for</span>=<span class="text-amber-300">"Body"</span>
        <span class="text-sky-300">toolbar</span>=<span class="text-amber-300">"full"</span>
        <span class="text-sky-300">skin</span>=<span class="text-amber-300">"gray"</span>
        <span class="text-sky-300">height</span>=<span class="text-amber-300">"540px"</span> <span class="text-pink-300">/&gt;</span>
    <span class="text-pink-300">&lt;button</span> <span class="text-sky-300">type</span>=<span class="text-amber-300">"submit"</span><span class="text-pink-300">&gt;</span>Save<span class="text-pink-300">&lt;/button&gt;</span>
<span class="text-pink-300">&lt;/form&gt;</span></code></pre>
        </div>
    </div>
</section>

